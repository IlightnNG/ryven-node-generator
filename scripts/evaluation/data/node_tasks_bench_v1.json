      "demo_stub_cases": [
        {"inputs": [10, 2], "expected_outputs": {"0": 5.0}, "strict": false},
        {"inputs": [1, 4], "expected_outputs": {"0": 0.25}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [5, 0], "expected_outputs": {"0": 0.0}, "strict": true},
        {"inputs": [3, null], "expected_outputs": {"0": 0.0}, "strict": true},
        {"inputs": [1, 0.0], "expected_outputs": {"0": 0.0}, "strict": true}
      ]
    },
    {
      "task_id": "N11",
      "band": "L2",
      "title": "Split Count",
