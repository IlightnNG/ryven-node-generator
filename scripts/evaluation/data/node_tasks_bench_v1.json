{
  "schema_version": "node_tasks_bench_v1",
  "description": "20 Ryven-style generator benchmark tasks (L1/L2/L3). Ports use type 'data' only unless noted. core_logic must use self.get_input_val(i) and self.set_output_val(j, Data(...)) per templates_v2. Stub cases align with ryven_node_generator.ai_assistant.core.stub_runner.evaluate_stub_cases (expected_outputs keys are output port indices as strings).",
  "tasks": [
    {
      "task_id": "N01",
      "band": "L1",
      "title": "Relay Data",
      "class_name_suggestion": "RelayDataNode",
      "description_zh": "单数据输入原样输出（恒等/中继），常用于调试连线。",
      "inputs": [
        {"label": "in", "type": "data"}
      ],
      "outputs": [
        {"label": "out", "type": "data"}
      ],
      "core_logic_requirement": "Read data port 0; write the same value to data output 0 as Data(...). Handle None by passing through or output Data(None) consistently.",
      "tags": ["basics", "identity"],
      "demo_stub_cases": [
        {"inputs": [42], "expected_outputs": {"0": 42}, "strict": true},
        {"inputs": ["hello"], "expected_outputs": {"0": "hello"}, "strict": true}
      ],
      "robust_stub_cases": [
        {"inputs": [null], "expected_outputs": {"0": null}, "strict": true},
        {"inputs": [0], "expected_outputs": {"0": 0}, "strict": true}
      ]
    },
    {
      "task_id": "N02",
      "band": "L1",
      "title": "Add Floats",
      "class_name_suggestion": "AddFloatsNode",
      "description_zh": "两路数值相加（需安全类型转换）。",
      "inputs": [
        {"label": "a", "type": "data"},
        {"label": "b", "type": "data"}
      ],
      "outputs": [
        {"label": "sum", "type": "data"}
      ],
      "core_logic_requirement": "Coerce a,b to float; if either is None, output Data(0.0) or document a single fallback policy and stick to it.",
      "tags": ["math", "arithmetic"],
      "demo_stub_cases": [
        {"inputs": [1, 2], "expected_outputs": {"0": 3.0}, "strict": false},
        {"inputs": [1.5, 2.5], "expected_outputs": {"0": 4.0}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [null, 5], "expected_outputs": {"0": 0.0}, "strict": false},
        {"inputs": ["3", 4], "expected_outputs": {"0": 7.0}, "strict": false}
      ]
    },
    {
      "task_id": "N03",
      "band": "L1",
      "title": "Multiply Floats",
      "class_name_suggestion": "MulFloatsNode",
      "description_zh": "两路数值相乘（需安全类型转换，禁止对非数值直接 *）。",
      "inputs": [
        {"label": "a", "type": "data"},
        {"label": "b", "type": "data"}
      ],
      "outputs": [
        {"label": "product", "type": "data"}
      ],
      "core_logic_requirement": "float(a)*float(b) with try/except or guards; None -> 0.0 or fixed policy.",
      "tags": ["math", "arithmetic"],
      "demo_stub_cases": [
        {"inputs": [2, 3], "expected_outputs": {"0": 6.0}, "strict": false},
        {"inputs": [-1, 4], "expected_outputs": {"0": -4.0}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [0, 99], "expected_outputs": {"0": 0.0}, "strict": false},
        {"inputs": ["2.5", 2], "expected_outputs": {"0": 5.0}, "strict": false}
      ]
    },
    {
      "task_id": "N04",
      "band": "L1",
      "title": "Max Of Two",
      "class_name_suggestion": "MaxTwoNode",
      "description_zh": "输出两数较大者（同类型比较或统一转 float）。",
      "inputs": [
        {"label": "a", "type": "data"},
        {"label": "b", "type": "data"}
      ],
      "outputs": [
        {"label": "max", "type": "data"}
      ],
      "core_logic_requirement": "Numeric max after coercion; if invalid, fallback consistent with N02.",
      "tags": ["math", "compare"],
      "demo_stub_cases": [
        {"inputs": [3, 7], "expected_outputs": {"0": 7}, "strict": false},
        {"inputs": [10, 2], "expected_outputs": {"0": 10}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [-5, -1], "expected_outputs": {"0": -1}, "strict": false},
        {"inputs": [null, 4], "expected_outputs": {"0": 4}, "strict": false}
      ]
    },
    {
      "task_id": "N05",
      "band": "L1",
      "title": "Concat Strings",
      "class_name_suggestion": "ConcatStrNode",
      "description_zh": "字符串拼接（需处理 None）。",
      "inputs": [
        {"label": "a", "type": "data"},
        {"label": "b", "type": "data"}
      ],
      "outputs": [
        {"label": "out", "type": "data"}
      ],
      "core_logic_requirement": "str(a)+str(b) with None -> empty string or fixed rule.",
      "tags": ["string"],
      "demo_stub_cases": [
        {"inputs": ["foo", "bar"], "expected_outputs": {"0": "foobar"}, "strict": true},
        {"inputs": ["", "x"], "expected_outputs": {"0": "x"}, "strict": true}
      ],
      "robust_stub_cases": [
        {"inputs": [null, "z"], "expected_outputs": {"0": "z"}, "strict": false},
        {"inputs": [123, "px"], "expected_outputs": {"0": "123px"}, "strict": true}
      ]
    },
    {
      "task_id": "N06",
      "band": "L1",
      "title": "Constant Pi",
      "class_name_suggestion": "ConstPiNode",
      "description_zh": "无输入常量源，输出圆周率（教学常用）。",
      "inputs": [],
      "outputs": [
        {"label": "pi", "type": "data"}
      ],
      "core_logic_requirement": "No get_input_val; set_output_val(0, Data(math.pi)).",
      "tags": ["source", "math"],
      "demo_stub_cases": [
        {"inputs": [], "expected_outputs": null, "strict": false, "note": "smoke only; optional strict check in harness"}
      ],
      "robust_stub_cases": [
        {"inputs": [], "expected_outputs": null, "strict": false}
      ],
      "acceptance_note": "For automated checks, use abs(out-math.pi)<1e-9 in a custom assert if strict JSON float is awkward."
    },
    {
      "task_id": "N07",
      "band": "L1",
      "title": "Absolute Value",
      "class_name_suggestion": "AbsValNode",
      "description_zh": "数值绝对值。",
      "inputs": [
        {"label": "x", "type": "data"}
      ],
      "outputs": [
        {"label": "abs_x", "type": "data"}
      ],
      "core_logic_requirement": "abs(float(x)) with safe coercion; invalid -> 0.0.",
      "tags": ["math"],
      "demo_stub_cases": [
        {"inputs": [-3], "expected_outputs": {"0": 3.0}, "strict": false},
        {"inputs": [2.5], "expected_outputs": {"0": 2.5}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [0], "expected_outputs": {"0": 0.0}, "strict": false},
        {"inputs": ["-4"], "expected_outputs": {"0": 4.0}, "strict": false}
      ]
    },
    {
      "task_id": "N08",
      "band": "L1",
      "title": "Clamp Scalar",
      "class_name_suggestion": "ClampScalarNode",
      "description_zh": "将 x 限制在 [lo, hi] 闭区间内。",
      "inputs": [
        {"label": "x", "type": "data"},
        {"label": "lo", "type": "data"},
        {"label": "hi", "type": "data"}
      ],
      "outputs": [
        {"label": "y", "type": "data"}
      ],
      "core_logic_requirement": "y = min(max(x, lo), hi) after float coercion; if lo>hi swap or reject with fixed policy.",
      "tags": ["math", "bounds"],
      "demo_stub_cases": [
        {"inputs": [5, 0, 10], "expected_outputs": {"0": 5.0}, "strict": false},
        {"inputs": [-1, 0, 10], "expected_outputs": {"0": 0.0}, "strict": false},
        {"inputs": [100, 0, 10], "expected_outputs": {"0": 10.0}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [3, 10, 0], "expected_outputs": {"0": 3.0}, "strict": false, "note": "if swap: expect 3 still in [0,10]"},
        {"inputs": [null, 0, 1], "expected_outputs": {"0": 0.0}, "strict": false}
      ]
    },
    {
      "task_id": "N09",
      "band": "L2",
      "title": "Weighted Sum",
      "class_name_suggestion": "WeightedSumNode",
      "description_zh": "计算 w1*x + w2*y（四路数据：x,y,w1,w2）。",
      "inputs": [
        {"label": "x", "type": "data"},
        {"label": "y", "type": "data"},
        {"label": "w1", "type": "data"},
        {"label": "w2", "type": "data"}
      ],
      "outputs": [
        {"label": "out", "type": "data"}
      ],
      "core_logic_requirement": "All operands coerced to float; formula w1*x+w2*y.",
      "tags": ["math", "linear"],
      "demo_stub_cases": [
        {"inputs": [1, 2, 1, 1], "expected_outputs": {"0": 3.0}, "strict": false},
        {"inputs": [2, 3, 0.5, 1], "expected_outputs": {"0": 4.0}, "strict": false}
      ],
      "robust_stub_cases": [
        {"inputs": [1, 1, null, 1], "expected_outputs": {"0": 1.0}, "strict": false},
        {"inputs": ["1", "2", "1", "1"], "expected_outputs": {"0": 3.0}, "strict": false}
      ]
    },
    {
      "task_id": "N10",
      "band": "L2",
      "title": "Safe Divide",
      "class_name_suggestion": "SafeDivideNode",
