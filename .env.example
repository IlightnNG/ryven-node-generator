# Copy to .env and fill in (do not commit .env)

# ---------- OpenAI ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- Alibaba Bailian (OpenAI-compatible) ----------
# Create API key in the Bailian console; use DASHSCOPE_API_KEY or OPENAI_API_KEY
# DASHSCOPE_API_KEY=sk-...
LLM_PROVIDER=dashscope
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Region: beijing (default) | singapore | us | hongkong
# DASHSCOPE_REGION=beijing

# Model id as shown in the console, e.g.:
OPENAI_MODEL=qwen3.5-flash

OPENAI_TEMPERATURE=0.2

# STRUCTURED_OUTPUT_MODE=auto | json_prompt | function_calling
# STRUCTURED_OUTPUT_MODE=auto

# AI_STREAM=true streams the assistant text; false returns one block
AI_STREAM=true

# ---------- Agent (ReAct) ----------
# AI_AGENT_MODE=react | legacy
# AI_AGENT_MAX_STEPS=24
# read / write / tool output caps
# AI_AGENT_MAX_READ_CHARS=200000
# AI_AGENT_MAX_WRITE_BYTES=512000
# AI_AGENT_MAX_TOOL_OUTPUT_CHARS=32000
# Shell tool (default off): single command, no && or pipes
# AI_AGENT_BASH=false
# AI_AGENT_SHELL_TIMEOUT=45
